rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin check function
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'himanshu0481@gmail.com' || 
         request.auth.token.email == 'admin@karigiri.com');
    }

    // Products collection: Anyone can read, only admin can write
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders collection: Anyone can create (checkout), only admin can manage
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Default: Deny all other collections unless specified
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}